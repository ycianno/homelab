    {
      "parameters": {
        "jsCode": "const app = $(\"Loop Applications\").item.json;\nconst cand = $(\"Get Candidate Info\").item.json.data[0];\nconst job = $(\"Get Job Info\").item.json.data[0];\nconst evalResult = $(\"Parse Ollama JSON\").item.json;\n\nlet recruiterEmail = \"ayciano@blackbirchgroup.com\";\nlet recruiterName = \"Recruiter\";\nif (job.Assigned_Recruiter) {\n  if (Array.isArray(job.Assigned_Recruiter) && job.Assigned_Recruiter.length > 0) {\n    recruiterEmail = job.Assigned_Recruiter[0].email || recruiterEmail;\n    recruiterName = job.Assigned_Recruiter[0].name || recruiterName;\n  } else {\n    recruiterEmail = job.Assigned_Recruiter.email || recruiterEmail;\n    recruiterName = job.Assigned_Recruiter.name || recruiterName;\n  }\n}\n\nreturn {\n  json: {\n    app_id: app.id,\n    name: cand.Full_Name || \"Unknown Candidate\",\n    job_title: job.Job_Opening_Name,\n    score: evalResult.score || 0,\n    rating: evalResult.rating || \"Error\",\n    summary: evalResult.summary || \"No evaluation details.\",\n    gaps: evalResult.gaps || [],\n    questions: evalResult.questions || [],\n    recruiter_email: recruiterEmail,\n    recruiter_name: recruiterName\n  }\n};"
      },
