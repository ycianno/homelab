    {
      "parameters": {
        "jsCode": "const stdout = $(\"Get Unsent from Cache\").first().json.stdout;\nconst unsentCandidates = JSON.parse(stdout);\n\nconst recruiterDigests = {};\n\nfor (const evalResult of unsentCandidates) {\n  let recruiterEmail = evalResult.recruiter_email || \"ayciano@blackbirchgroup.com\";\n  let recruiterName = evalResult.recruiter_name || \"Recruiter\";\n  \n  if (!recruiterDigests[recruiterEmail]) {\n    recruiterDigests[recruiterEmail] = {\n      recruiter_email: recruiterEmail,\n      recruiter_name: recruiterName,\n      candidates: {\n        Green: [],\n        Yellow: [],\n        Red: [],\n        Error: []\n      }\n    };\n  }\n  \n  const rating = evalResult.rating || \"Error\";\n  recruiterDigests[recruiterEmail].candidates[rating].push({\n    name: evalResult.name || \"Unknown Candidate\",\n    job_title: evalResult.job_title,\n    score: evalResult.score || 0,\n    summary: evalResult.summary || \"No evaluation details.\",\n    gaps: evalResult.gaps || [],\n    questions: evalResult.questions || [],\n    app_id: evalResult.app_id\n  });\n}\n\nconst output = [];\n\nfor (const email of Object.keys(recruiterDigests)) {\n  const digest = recruiterDigests[email];\n  let html = `<h3>\ud83d\udcca New Candidates Pending Review</h3>`;\n  html += `<p>Hello ${digest.recruiter_name}, here is your daily candidate evaluation summary.</p><hr/>`;\n  \n  const categories = [\"Green\", \"Yellow\", \"Red\"];\n  const colors = { Green: \"\ud83d\udfe2 Good to Invite First\", Yellow: \"\ud83d\udfe1 Verify Gaps First\", Red: \"\ud83d\udd34 Manual Review\" };\n  const borderColors = { Green: \"#28a745\", Yellow: \"#ffc107\", Red: \"#dc3545\" };\n  \n  let totalCount = 0;\n  for (const cat of categories) {\n    const list = digest.candidates[cat];\n    totalCount += list.length;\n    if (list.length === 0) continue;\n    \n    html += `<h4>${colors[cat]} (${list.length})</h4>`;\n    html += `<table border=\"1\" cellpadding=\"8\" style=\"border-collapse: collapse; width: 100%; border: 1px solid #ccc; font-family: sans-serif; font-size: 14px; margin-bottom: 20px;\">`;\n    html += `<tr style=\"background-color: #f8f9fa;\">`;\n    html += `<th align=\"left\" style=\"width: 25%;\">Candidate</th>`;\n    html += `<th align=\"left\" style=\"width: 25%;\">Applied For</th>`;\n    html += `<th align=\"left\" style=\"width: 10%;\">Score</th>`;\n    if (cat === \"Yellow\") {\n      html += `<th align=\"left\" style=\"width: 40%;\">Key Gaps & Suggested Questions</th>`;\n    } else {\n      html += `<th align=\"left\" style=\"width: 40%;\">AI reasoning / Summary</th>`;\n    }\n    html += `</tr>`;\n    \n    for (const item of list) {\n      const zohoLink = `https://recruit.zoho.com/recruit/EntityInfo.do?module=Applications&id=${item.app_id}`;\n      html += `<tr>`;\n      html += `<td><strong>${item.name}</strong><br/><a href=\"${zohoLink}\" target=\"_blank\" style=\"color: #007bff; text-decoration: none; font-size: 12px;\">Open in Zoho</a></td>`;\n      html += `<td>${item.job_title}</td>`;\n      html += `<td style=\"font-weight: bold; color: ${borderColors[cat]};\">${item.score}/100</td>`;\n      \n      if (cat === \"Yellow\") {\n        html += `<td>`;\n        if (item.gaps.length > 0) {\n          html += `<strong>Identified Gaps:</strong><ul>` + item.gaps.map(g => `<li>${g}</li>`).join(\"\") + `</ul>`;\n        }\n        if (item.questions.length > 0) {\n          html += `<strong>Suggested Questions:</strong><ul>` + item.questions.map(q => `<li>${q}</li>`).join(\"\") + `</ul>`;\n        }\n        html += `</td>`;\n      } else {\n        html += `<td>${item.summary}</td>`;\n      }\n      html += `</tr>`;\n    }\n    html += `</table>`;\n  }\n  \n  if (totalCount > 0) {\n    output.push({\n      json: {\n        to_email: email,\n        subject: `\ud83d\udccb [Daily Digest] ${totalCount} Candidates Pending Review`,\n        html_body: html\n      }\n    });\n  }\n}\n\nreturn output;"
      },
