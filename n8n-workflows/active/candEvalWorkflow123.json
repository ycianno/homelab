    },
    {
      "parameters": {
        "jsCode": "const attachments = $json.data;\nif (!attachments || attachments.length === 0) {\n  return { json: { isValid: false, reason: \"No resume attached\" } };\n}\nconst first = attachments[0];\nif (!first.File_Name || first.Size === \"0\" || first[\"$file_id\"] === \"-1\") {\n  return { json: { isValid: false, reason: \"Invalid or empty resume file\" } };\n}\nreturn { json: { isValid: true, attachment_id: first.id } };"
      },
